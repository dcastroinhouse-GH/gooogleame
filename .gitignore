# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# Supabase (Local environments)
/supabase/.temp/
/supabase/.branch/
supabase/functions/**/.env

# misc
.DS_Store
*.pem
*.log

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (NEVER COMMIT THESE)
.env
.env*.local
.env.development
.env.production
.env.test

# BUT explicitly allow example files so the team knows what envs to use
!.env.example
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
